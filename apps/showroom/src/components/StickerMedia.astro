---
import type { GallerySticker } from "../data/sticker-gallery";
import { stickerMediaUrl } from "../data/sticker-gallery";

interface Props {
  sticker: GallerySticker;
  src: string;
  alt: string;
  decorative?: boolean;
}

const { sticker, src, alt, decorative = false } = Astro.props;
const firstFrameSrc =
  sticker.kind === "animated" && sticker.sourceFormat === "video"
    ? stickerMediaUrl({ assetPath: sticker.firstFrameAssetPath })
    : undefined;
---

{
  sticker.kind === "animated" ? (
    <span
      class="cf-animated-sticker astro-sticker-gallery-media"
      data-cf-animated-sticker
      data-state="loading"
      role={decorative ? undefined : "img"}
      aria-label={decorative ? undefined : alt}
      aria-hidden={decorative || undefined}
    >
      <span class="cf-animated-sticker__skeleton" aria-hidden="true">
        {sticker.sourceFormat === "tgs" ? (
          <Fragment set:html={sticker.skeletonSvg} />
        ) : (
          <img
            src={firstFrameSrc}
            width={sticker.width}
            height={sticker.height}
            loading="lazy"
            decoding="async"
            alt=""
          />
        )}
      </span>
      <video
        data-cf-animated-sticker-video
        data-cf-animated-sticker-src={src}
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      />
    </span>
  ) : (
    <img
      class="astro-sticker-gallery-media"
      src={src}
      width={sticker.width}
      height={sticker.height}
      loading="lazy"
      decoding="async"
      alt={decorative ? "" : alt}
    />
  )
}
